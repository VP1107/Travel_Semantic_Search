# ─────────────────────────────────────────
# Python
# ─────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
pip-wheel-metadata/
*.whl

# Virtual environments
.venv/
venv/
env/
ENV/

# Type stubs
*.pyi

# ─────────────────────────────────────────
# Environment & Secrets
# ─────────────────────────────────────────
.env
.env.*
!.env.example      # keep the example template committed

# ─────────────────────────────────────────
# Logs
# ─────────────────────────────────────────
logs/
*.log
*.log.*

# ─────────────────────────────────────────
# Data & Large Files
# ─────────────────────────────────────────
data/
*.json.gz
*.csv
*.parquet
*.pkl
*.pickle
# Keep tracked JSON fixtures but ignore the huge portal dump
destissp_portal.json

# ─────────────────────────────────────────
# Embeddings / ML artefacts
# ─────────────────────────────────────────
*.npy
*.npz
*.faiss
*.index
*.bin

# ─────────────────────────────────────────
