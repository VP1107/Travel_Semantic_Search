# ─────────────────────────────────────────
frontend/node_modules/
frontend/.next/
frontend/out/
frontend/dist/
frontend/build/
frontend/.env
frontend/.env.local
frontend/.env.*.local
frontend/.vercel/
frontend/package-lock.json   # uncomment if you prefer yarn or pnpm
# frontend/yarn.lock           # uncomment if you use npm

# ─────────────────────────────────────────
